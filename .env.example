# 네이버 개발자센터 (developers.naver.com)
NAVER_CLIENT_ID=여기에입력
NAVER_CLIENT_SECRET=여기에입력
# Google Cloud Console (console.cloud.google.com)
GOOGLE_API_KEY=여기에입력

# Google AI Studio (aistudio.google.com)
GEMINI_API=여기에입력

# Kakao Developers (developers.kakao.com) — REST API 키
# 앱 생성 → 앱 키 → REST API 키 복사
KAKAO_REST_API_KEY=여기에입력

APP_TOKEN=여기에입력